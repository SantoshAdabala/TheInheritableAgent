# ─────────────────────────────────────────────────────────────────
# Auth0 Configuration
# Dashboard → Applications → Your App → Settings
# App type must be: Regular Web Application (NOT SPA / Native)
# Grant Types (Advanced Settings): enable Token Vault
# Authentication Method (Advanced Settings): Private Key JWT
# ─────────────────────────────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_client_id

FLASK_SECRET_KEY=change-this-to-a-long-random-string
FLASK_ENV=development

# Groq API — free at console.groq.com (no credit card required)
GROQ_API_KEY=gsk_...
